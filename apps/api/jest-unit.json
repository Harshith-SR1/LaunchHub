{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": "test/unit/.*\\.spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testEnvironment": "node",
  "verbose": true,
  "moduleNameMapper": {
    "^(.*)\\.js$": "$1",
    "^src\\/(.*)$": "<rootDir>/src/$1"
  }
}

