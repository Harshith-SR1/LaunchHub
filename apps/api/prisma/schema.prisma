generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum AuthProvider {
  LOCAL
  GOOGLE
  GITHUB
  LINKEDIN
}

enum MfaMethod {
  TOTP
  EMAIL
  SMS
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  VERIFIED
  REJECTED
}

enum ProjectStatus {
  DRAFT
  OPEN
  IN_REVIEW
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProposalStatus {
  SUBMITTED
  SHORTLISTED
  INTERVIEWING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum AssetStatus {
  DRAFT
  LISTED
  RESERVED
  IN_ESCROW
  SOLD
  ARCHIVED
}

enum DomainDealType {
  BUY
  SELL
  AUCTION
  LEASE
}

enum TransactionStatus {
  PENDING
  AUTHORIZED
  CAPTURED
  REFUNDED
  FAILED
}

enum EscrowStatus {
  CREATED
  FUNDED
  RELEASED
  DISPUTED
  CANCELLED
}

enum ConversationType {
  DIRECT
  GROUP
  PROJECT
  DEAL
}

enum NotificationType {
  SYSTEM
  MESSAGE
  PAYMENT
  KYC
  MARKETPLACE
  AI_INSIGHT
}

enum ReviewTargetType {
  USER
  PROJECT
  DOMAIN
  WEBSITE
  APP
  STARTUP
}

enum AiReportType {
  STARTUP_BUILDER
  DOMAIN_ANALYSIS
  RISK_ASSESSMENT
  COST_ESTIMATION
  TIMELINE_PREDICTION
  ENGINEER_RECOMMENDATION
}

enum FundingStage {
  PRE_SEED
  SEED
  SERIES_A
  SERIES_B
  SERIES_C
  GROWTH
}

model User {
  id                String              @id @default(cuid())
  email             String              @unique
  username          String              @unique
  fullName          String
  avatarUrl         String?
  phoneNumber       String?
  passwordHash      String?
  status            UserStatus          @default(PENDING)
  emailVerifiedAt   DateTime?
  lastLoginAt       DateTime?
  locale            String              @default("en")
  timezone          String              @default("UTC")
  onboardingDoneAt  DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?

  roles             UserRoleAssignment[]
  profile           Profile?
  sessions          Session[]
  mfa               MfaSecret?
  oauthAccounts     OAuthAccount[]
  verificationTokens VerificationToken[]
  passwordResets    PasswordResetToken[]
  kyc               KycProfile?
  projects          Project[]
  proposals         Proposal[]
  domainListings    DomainListing[]
  websiteListings   WebsiteListing[]
  appListings       AppListing[]
  investments       Investment[]
  transactions      Transaction[]
  escrowsAsBuyer    Escrow[]            @relation("EscrowBuyer")
  escrowsAsSeller   Escrow[]            @relation("EscrowSeller")
  messages          Message[]
  notifications     Notification[]
  reviewsGiven      Review[]            @relation("ReviewsGiven")
  reviewsReceived   Review[]            @relation("ReviewsReceived")
  aiReports         AiReport[]
  auditLogs         AuditLog[]
  watchlistEntries   DomainWatchlist[]
  domainRegistrations DomainRegistration[]
  startupsFounded   StartupListing[]
}

model Role {
  id          String              @id @default(cuid())
  name        String              @unique
  description String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  users       UserRoleAssignment[]
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  assignedAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
}

model Profile {
  id               String   @id @default(cuid())
  userId           String   @unique
  headline         String?
  bio              String?
  avatarUrl        String?
  companyName      String?
  websiteUrl       String?
  linkedinUrl      String?
  githubUrl        String?
  skills           String[]  @default([])
  hourlyRate       Decimal?  @db.Decimal(10, 2)
  availability     String?
  location         String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  refreshTokenHash String
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MfaSecret {
  id            String    @id @default(cuid())
  userId        String    @unique
  secret        String
  method        MfaMethod @default(TOTP)
  enabled       Boolean   @default(false)
  tempSecret    String?
  backupCodes   String[]   @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id                  String        @id @default(cuid())
  userId              String
  provider            AuthProvider
  providerAccountId   String
  accessToken         String?
  refreshToken        String?
  expiresAt           DateTime?
  scope               String?
  idToken             String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  token      String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model KycProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  status          KycStatus  @default(NOT_SUBMITTED)
  legalName       String?
  country         String?
  documentType    String?
  documentNumber  String?
  documentFrontUrl String?
  documentBackUrl String?
  selfieUrl       String?
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  submittedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id              String         @id @default(cuid())
  ownerId         String
  title           String
  slug            String         @unique
  description     String
  budgetMin       Decimal?       @db.Decimal(14, 2)
  budgetMax       Decimal?       @db.Decimal(14, 2)
  currency        String         @default("USD")
  timelineDays    Int?
  status          ProjectStatus  @default(DRAFT)
  requiredSkills  String[]       @default([])
  attachmentsUrl  String[]       @default([])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  owner           User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  proposals       Proposal[]
  aiReports       AiReport[]     @relation("ProjectAiReports")

  @@index([ownerId, status])
}

model Proposal {
  id            String         @id @default(cuid())
  projectId     String
  engineerId    String
  coverLetter   String
  price         Decimal        @db.Decimal(14, 2)
  currency      String         @default("USD")
  estimatedDays Int
  status        ProposalStatus @default(SUBMITTED)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  project       Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  engineer      User           @relation(fields: [engineerId], references: [id], onDelete: Cascade)

  @@index([projectId, status])
  @@index([engineerId])
}

model DomainListing {
  id            String         @id @default(cuid())
  ownerId       String
  domainName    String         @unique
  title         String
  description   String?
  dealType      DomainDealType @default(BUY)
  status        AssetStatus    @default(LISTED)
  askingPrice   Decimal?       @db.Decimal(14, 2)
  leasePrice    Decimal?       @db.Decimal(14, 2)
  currency      String         @default("USD")
  expiryDate    DateTime?
  registrarName String?
  valuation     Decimal?       @db.Decimal(14, 2)
  brandabilityScore Int?
  seoScore      Int?
  trademarkRisk Int?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  watchlists    DomainWatchlist[]
  registrations DomainRegistration[]

  @@index([status, dealType])
}

model DomainWatchlist {
  id           String   @id @default(cuid())
  userId       String
  domainId     String
  alertOnExpiry Boolean  @default(true)
  alertOnPrice  Boolean  @default(true)
  createdAt    DateTime  @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain       DomainListing @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([userId, domainId])
}

model DomainRegistration {
  id            String   @id @default(cuid())
  domainId      String
  userId        String
  providerName  String
  operation     String
  dnsRecords    Json?
  whoisPrivacy  Boolean   @default(true)
  renewalDate   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  domain        DomainListing @relation(fields: [domainId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebsiteListing {
  id            String        @id @default(cuid())
  ownerId       String
  title         String
  slug          String        @unique
  category      String
  status        AssetStatus   @default(LISTED)
  askingPrice   Decimal       @db.Decimal(14, 2)
  revenueMrr    Decimal?      @db.Decimal(14, 2)
  traffic       Int?
  seoScore      Int?
  growthRate    Float?
  techStack     String[]      @default([])
  analyticsUrl  String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  owner         User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model AppListing {
  id            String        @id @default(cuid())
  ownerId       String
  title         String
  slug          String        @unique
  category      String
  status        AssetStatus   @default(LISTED)
  askingPrice   Decimal       @db.Decimal(14, 2)
  downloads     Int?
  revenueMrr    Decimal?      @db.Decimal(14, 2)
  activeUsers   Int?
  techStack     String[]      @default([])
  sourceCodeStatus String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  owner         User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model StartupListing {
  id            String        @id @default(cuid())
  founderId     String
  name          String
  slug          String        @unique
  description   String
  stage         FundingStage  @default(PRE_SEED)
  askingPrice   Decimal?      @db.Decimal(14, 2)
  revenueMrr    Decimal?      @db.Decimal(14, 2)
  valuation     Decimal?      @db.Decimal(14, 2)
  status        AssetStatus   @default(LISTED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  founder       User          @relation(fields: [founderId], references: [id], onDelete: Cascade)
  investments   Investment[]
}

model Investment {
  id            String   @id @default(cuid())
  investorId    String
  startupId     String?
  amount        Decimal  @db.Decimal(14, 2)
  currency      String   @default("USD")
  sharePercent  Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  investor      User     @relation(fields: [investorId], references: [id], onDelete: Cascade)
  startup       StartupListing? @relation(fields: [startupId], references: [id], onDelete: SetNull)
}

model Transaction {
  id              String            @id @default(cuid())
  userId          String
  provider        AuthProvider?     
  paymentProvider String
  status          TransactionStatus  @default(PENDING)
  type            String
  amount          Decimal           @db.Decimal(14, 2)
  currency        String            @default("USD")
  referenceId     String?           @unique
  metadata        Json?
  processedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  escrow          Escrow?
}

model Escrow {
  id              String        @id @default(cuid())
  buyerId         String
  sellerId        String
  transactionId   String         @unique
  status          EscrowStatus   @default(CREATED)
  amount          Decimal        @db.Decimal(14, 2)
  currency        String         @default("USD")
  milestoneRules  Json?
  releasedAt      DateTime?
  disputedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  buyer           User           @relation("EscrowBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller          User           @relation("EscrowSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  transaction     Transaction    @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}

model Conversation {
  id              String            @id @default(cuid())
  type            ConversationType   @default(DIRECT)
  title           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  messages        Message[]
}

model Message {
  id              String   @id @default(cuid())
  conversationId  String
  senderId        String
  body            String
  attachmentUrls  String[]  @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model Notification {
  id           String             @id @default(cuid())
  userId       String
  type         NotificationType    @default(SYSTEM)
  title        String
  body         String
  metadata     Json?
  readAt       DateTime?
  createdAt    DateTime           @default(now())

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model Review {
  id             String            @id @default(cuid())
  reviewerId     String
  targetUserId   String?
  targetType     ReviewTargetType
  targetId       String
  rating         Int
  title          String?
  comment        String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  reviewer       User              @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  targetUser     User?             @relation("ReviewsReceived", fields: [targetUserId], references: [id], onDelete: SetNull)
}

model AiReport {
  id             String         @id @default(cuid())
  userId         String
  projectId      String?
  reportType     AiReportType
  title          String
  summary        String
  payload        Json
  confidence     Float?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project        Project?       @relation("ProjectAiReports", fields: [projectId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String
  entityType   String
  entityId     String?
  ipAddress    String?
  userAgent    String?
  metadata     Json?
  createdAt    DateTime @default(now())

  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([userId, createdAt])
}
